{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "DOM",
      "ESNext"
    ],
    "moduleResolution": "bundler", // Vite
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    // "strict": true,
    "esModuleInterop": true, // Needed for Nextjs and Electron
    "types": [
      "react",
      "react-dom"
    ]
  },
  "exclude": [
    "node_modules"
  ]
}